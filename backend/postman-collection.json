          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Pagination returns 200', function() {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Pagination metadata is present', function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.meta.hasMore).to.be.a('boolean');",
                  "});"
                ]
              }
            }
          ]
