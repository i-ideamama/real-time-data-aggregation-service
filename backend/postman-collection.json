        {
          "name": "Get Token by Address - Happy Path",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/tokens/{{token_address}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tokens", "{{token_address}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Get token by address - Status 200 or 404', function() {",
